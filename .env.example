# Copy this file to .env and fill in your values
# The server reads from .env — never commit .env to git

PORT=3001

# Secret key the dashboard uses to authenticate with this backend
# Set the same value in the dashboard Settings > API Keys > Backend Connection
API_SECRET_KEY=change-me-to-something-secret

# EZTexting credentials (Basic auth)
EZTEXTING_USERNAME=your@email.com
EZTEXTING_PASSWORD=yourpassword

# Bandwidth credentials
BANDWIDTH_ACCOUNT_ID=12345678
BANDWIDTH_API_TOKEN=your-token
BANDWIDTH_API_SECRET=your-secret
BANDWIDTH_SAVVY_SITE_TAG=Stafford
BANDWIDTH_MITEL_SITE_TAG=Mitel

# Monday.com credentials
MONDAY_API_KEY=your-monday-api-key
MONDAY_BOARD_ID=your-board-id
MONDAY_STATUS_COLUMN_ID=status_column_id
MONDAY_HERE_LABEL=Here
MONDAY_STANDBY_LABEL=Standby

# Wix credentials (used by callcenter-ops.html legacy dashboard)
WIX_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WIX_API_KEY=your-wix-api-key
WIX_COLLECTION_NAME=SystemStatus

# JSONBin credentials are entered in the CCOB Dashboard UI (Settings > API Keys)
# and stored in browser localStorage — they are NOT needed here
